# DNSStudy-CTMonitor Environment Variables

# --- PostgreSQL (used by ct-stream-filter sidecar) ---
POSTGRES_HOST=dnsstudy-postgres
POSTGRES_PORT=5432
POSTGRES_DB=dnsstudy
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme

# --- DNSStudy API (used by ct-watcher hook and heartbeats) ---
DNSSTUDY_API_URL=http://dnsstudy-api:8000

# --- Certstream (used by ct-stream-filter) ---
CERTSTREAM_WS_URL=ws://certstream:8080/

# --- ct-stream-filter sidecar ---
PATTERN_RELOAD_INTERVAL=300
HEARTBEAT_INTERVAL=60

# --- ct-watcher (CertSpotter) ---
WATCHLIST_REFRESH_INTERVAL=300
